* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  overflow-x: hidden;
}

body {
  margin: 40px;
  padding: 5px;
  background-image: url(../src/assets/images/Desktop\ -\ 1\ \(1\).png);
  background-color: black;
  background-repeat: no-repeat;
  color: whitesmoke;
}

.logo {
  font-family: "Poppins";
  font-weight: bold;
  font-size: larger;
}

.nav-bar {
  display: flex;
  align-items: center;
  width: 100%;
  justify-content: flex-end;
}

.nav-bar {
  display: flex;
  align-items: center;
  width: 100%;
  justify-content: flex-end;
}

.container {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

ul {
  list-style-type: none;
  overflow: hidden;
  display: flex;
  margin-right: 10em;
}

li a {
  text-decoration: none;
  display: flex;
  padding: 8px;
  color: whitesmoke;
  transition: 0.3s ease;
}

li a.active {
  color: #38bdf8;
  font-weight: bold;
  border-bottom: 2px solid #38bdf8;
}

li a:hover {
  color: #38bdf8;
}

header {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  background-color: transparent;
}

.me {
  font-family: "Poppins", sans-serif;
  font-weight: 100;
  font-style: normal;
}

.intro {
  padding-top: 10em;
}

.hero-talk {
  padding-top: 15px;
  max-width: 30em;
  line-height: 24px;
  word-spacing: 50;
  font-size: 20px;
  font-family: "Poppins", sans-serif;
  font-weight: 150;
  font-style: normal;
}

.hero-btn {
  display: flex;
  gap: 28px;
  margin-top: 20px;
}

.btn-primary {
  padding: 10px;
  border-radius: 10px;
  background-color: #4d3f3f;
  text-decoration: none;
  color: whitesmoke;
}

.btn-secondary {
  background-color: #aaaaaa;
  border-radius: 10px;
  padding: 9px;
  text-decoration: none;
  color: whitesmoke;
}

.contact {
  padding-top: 80px;
  justify-content: center;
  display: flex;
  gap: 10px;
}

.contact-info {
  font-size: 15px;
  font-family: Arial, Helvetica, sans-serif;
}

input,
input:focus {
  border: 3px solid;
  padding: 8px;
  width: 260px;
  height: 20px;
  margin-bottom: 4px;
  color: black;
  border-radius: 10px;
  outline: none;
}

textarea,
textarea:focus {
  outline: none;
  padding: 6px;
}

.field {
  margin-bottom: 5px;
}

fieldset {
  align-items: center;
  justify-content: center;
  border: 1px solid;
  border-radius: 30px;
  max-width: 35em;
  padding: 25px;
  margin: 5px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

form {
  padding: 20px;
  margin-left: 50px;
}

button {
  padding: 6px;
}

footer {
  text-align: center;
  padding-top: 10px;
  margin-top: 15px;
}

.social-icon a {
  margin: 0 10px;
  font-size: 1.5rem;
  transition: 0.3s ease;
  color: #fff;
}

.social-icon a:hover {
  color: #38bdf8; /* nice modern blue */
  transform: translateY(-3px);
}

.icon {
  font-size: 1.5rem;
  cursor: pointer;
  display: none;
}

@media (max-width: 990px) {
  .intro {
    text-align: center;
  }

  .me {
    text-align: center;
  }

  .hero-talk {
    text-align: center;
  }

  .hero-btn {
    text-align: center;
  }

  .contact {
    display: block;
    max-width: 210px;
  }

  .icon {
    display: block;
  }

  .container .nav-link {
    flex-direction: column;
    position: absolute;
    width: 100%;
    height: 90vh;
    top: -100%;
    left: 0;
    left: 0;
    background-color: #0f172a;
    color: #fff;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    transition: 0.3s ease;
    margin: 3px;
    padding-left: 20rem;
  }

  .nav-link.active {
    top: 70px;
    transition: 0.3s ease;
  }
}

@media (max-width: 768px) {
  body {
    margin: 0;
    padding: 0;
    background-size: cover;
    background-position: center;
    overflow-x: hidden;
  }

  .container {
    width: 100vw;
    padding: 15px;
    margin-left: -50vw;
    margin-right: -50vw;
    left: 50%;
    right: 50%;
  }

  ul {
    margin-right: 0;
  }

  .hero-talk {
    max-width: 100%;
    font-size: 16px;
    margin: 0 auto;
  
  .contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 100vw;
    padding: 40px 0;
    gap: 20px;
  }

  fieldset {
    width: 90%;
    max-width: 100%;
    padding: 20px;
    margin: 10px auto;
  }

  input,
  input:focus {
    width: 100%;
    max-width: none;
  }

  textarea {
    width: 100%;
    max-width: none;
    cols: auto !important;
    rows: 5;
  }

  form {
    padding: 10px;
    margin-left: 0;
    width: 100%;
  }

  .contact-info {
    font-size: 14px;
    width: 100%;
  }

  .intro {
    width: 100%;
  }
}
